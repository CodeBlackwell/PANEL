# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o            # Strong model: PRD drafting, moderator synthesis
MODEL_NAME_FAST=gpt-4o-mini  # Fast model: clarification, debate agents, judges

# Debate Configuration
DEFAULT_DEBATE_ROUNDS=5
MAX_DEBATE_ROUNDS=15
MAX_CLARIFICATION_ROUNDS=10

# Storage
STORAGE_PATH=./sessions

# Session
SESSION_TIMEOUT_MINUTES=60

# CORS — comma-separated origins (add your production domain)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# JWT — leave blank to auto-generate (set explicitly for multi-instance deployments)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Token encryption — leave blank to auto-generate (set explicitly for multi-instance deployments)
TOKEN_ENCRYPTION_KEY=

# GitHub OAuth (optional — enables GitHub login + repo integration)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173
